SECRET_KEY=dev-secret-key-change-in-production
DATABASE_URL=sqlite:///./secure_room.db
UPLOAD_DIR=./uploads
CHROMA_DIR=./data/chroma
BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# ── Security / runtime mode ──────────────────────────────────────────────────
# DEV_MODE=true surfaces the email verification code in the API response so the
# join flow can be tested without email infrastructure. MUST be false in prod.
# When DEV_MODE=false, the app refuses to start with the default SECRET_KEY.
DEV_MODE=true

# Verification code policy
CODE_TTL_MINUTES=10
CODE_MAX_ATTEMPTS=5

# Recipient session lifetime (hours) after accepting terms
SESSION_TTL_HOURS=12

# Q&A rate limiting (per accessor, per room) — deters bulk content extraction
QA_RATE_MAX=15
QA_RATE_WINDOW_SECONDS=60

# Upload limits
MAX_UPLOAD_BYTES=52428800        # 50 MB
MIN_PASSWORD_LENGTH=8

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Set LLM_PROVIDER to "anthropic" (default) or "mlx" (local MLX model).
LLM_PROVIDER=anthropic

# ── Anthropic (cloud) ─────────────────────────────────────────────────────────
# Required when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key-here
# Override the model (default: claude-sonnet-4-6)
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ── MLX (local) ───────────────────────────────────────────────────────────────
# Used when LLM_PROVIDER=mlx
# Start the MLX server first: cd local-ai/mlx && ./start.sh
# The server exposes an OpenAI-compatible API at http://localhost:8080/v1
#
# MLX_BASE_URL=http://localhost:8080/v1
# MLX_MODEL=mlx-community/Qwen3.5-4B-MLX-4bit
