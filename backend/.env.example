SECRET_KEY=dev-secret-key-change-in-production
DATABASE_URL=sqlite:///./secure_room.db
UPLOAD_DIR=./uploads
CHROMA_DIR=./data/chroma
BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Set LLM_PROVIDER to "anthropic" (default) or "ollama" (local model).
LLM_PROVIDER=anthropic

# ── Anthropic (cloud) ─────────────────────────────────────────────────────────
# Required when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key-here
# Override the model (default: claude-sonnet-4-6)
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Ollama (local) ────────────────────────────────────────────────────────────
# Used when LLM_PROVIDER=ollama
# Install Ollama: https://ollama.com  →  ollama pull llama3.2
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2
