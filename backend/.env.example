SECRET_KEY=dev-secret-key-change-in-production
DATABASE_URL=sqlite:///./secure_room.db
UPLOAD_DIR=./uploads
CHROMA_DIR=./data/chroma
BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# ── Security / runtime mode ──────────────────────────────────────────────────
# DEV_MODE=true surfaces the email verification code in the API response so the
# join flow can be tested without email infrastructure. MUST be false in prod.
# When DEV_MODE=false, the app refuses to start with the default SECRET_KEY.
DEV_MODE=true

# Verification code policy
CODE_TTL_MINUTES=10
CODE_MAX_ATTEMPTS=5

# Recipient session lifetime (hours) after accepting terms
SESSION_TTL_HOURS=12

# Q&A rate limiting (per accessor, per room) — deters bulk content extraction
QA_RATE_MAX=15
QA_RATE_WINDOW_SECONDS=60

# Upload limits (PDF only)
MAX_UPLOAD_BYTES=52428800        # 50 MB
MAX_PDF_PAGES=200                # uploads above this page count are rejected
MIN_PASSWORD_LENGTH=8

# ── Ephemeral sandbox identity (optional) ────────────────────────────────────
# Identifier of the disposable sandbox this backend runs in. When set together
# with an Azure Tables config (below), recipient session lifecycle (logged_in_at,
# last_activity, status active|closed) is mirrored to an Azure Table named
# "sessions" (PartitionKey="sandbox", RowKey=SANDBOX_ID) so an external cleanup
# listener can destroy the sandbox after the engagement ends. Leave unset to
# skip the mirror (local session_activity rows are still kept).
# SANDBOX_ID=

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Set LLM_PROVIDER to "anthropic" (default) or "local" (any local
# OpenAI-compatible server: Ollama, MLX, llama.cpp, ...).
# "mlx" is still accepted as a backward-compatible alias for "local".
LLM_PROVIDER=anthropic

# ── Anthropic (cloud) ─────────────────────────────────────────────────────────
# Required when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key-here
# Override the model (default: claude-sonnet-4-6)
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Local LLM (Ollama / MLX / any OpenAI-compatible server) ──────────────────
# Used when LLM_PROVIDER=local
# Default points at Ollama's OpenAI-compatible endpoint.
# LOCAL_LLM_BASE_URL=http://localhost:11434/v1
# Model name/alias (default: qwen3-8b — the llama-server alias; llama-server
# largely ignores the name and serves whatever model it was started with)
# LOCAL_LLM_MODEL=qwen3-8b
# Max tokens for the generated answer (default 1024)
# LOCAL_LLM_MAX_TOKENS=1024
# Reasoning models (Qwen3) burn the token budget on a <think> channel and return
# an empty answer. Keep thinking disabled for this extraction-style RAG task.
# LOCAL_LLM_DISABLE_THINKING=true
#
# Legacy MLX_* variables (MLX_BASE_URL, MLX_MODEL, MLX_MAX_TOKENS,
# MLX_DISABLE_THINKING) are still honored when the LOCAL_LLM_* ones are unset.

# ── Azure Tables mirror for Q&A insights + session lifecycle (optional) ─────
# If either variable is set, every qa_insights row is mirrored to an Azure
# Table named "insights" (PartitionKey=room_id, RowKey=insight id), and — when
# SANDBOX_ID is also set — recipient session lifecycle is mirrored to a table
# named "sessions" (PartitionKey="sandbox", RowKey=SANDBOX_ID).
# Leave both unset for local-only operation (no errors).
# Endpoint mode authenticates with DefaultAzureCredential (az login / MI).
# AZURE_TABLES_ENDPOINT=https://<storage-account>.table.core.windows.net
# ...or use a connection string instead:
# AZURE_TABLES_CONNECTION_STRING=

# ── Verification email via Azure Communication Services (optional) ───────────
# If BOTH are set, the 6-digit join verification code is sent by real email
# and is never included in the API response (overrides the DEV_MODE mock).
# ACS_CONNECTION_STRING=endpoint=https://<acs-resource>.communication.azure.com/;accesskey=...
# ACS_SENDER_ADDRESS=DoNotReply@<verified-domain>
